# =============================================
# AI ASSISTANT PRO — Environment Variables
# =============================================

# === REQUIRED ===
# Free key: https://console.groq.com (30 seconds signup)
GROQ_API_KEY=your_groq_api_key_here

# Models (all free on Groq):
# llama3-8b-8192       fastest, great for chat
# llama3-70b-8192      smarter, complex reasoning
# mixtral-8x7b-32768   best for long docs
GROQ_MODEL=llama3-8b-8192

# Vision model (for image understanding)
GROQ_VISION_MODEL=llava-v1.5-7b-4096-preview

# === PERSISTENT MEMORY (Supabase - Free) ===
# 1. Go to https://supabase.com → New project (free)
# 2. Go to Settings → API → copy URL and anon key
# 3. Run this SQL in Supabase SQL Editor:
#    CREATE TABLE sessions (
#      session_id TEXT PRIMARY KEY,
#      messages TEXT,
#      created_at FLOAT,
#      updated_at FLOAT
#    );
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key

# === OPTIONAL TOOLS ===
# Web search: https://serper.dev (free tier: 2500 searches)
SERPER_API_KEY=

# Weather: https://openweathermap.org/api (free tier)
OPENWEATHER_KEY=

# Local memory fallback (used when Supabase not configured)
MEMORY_DIR=./data/memory
